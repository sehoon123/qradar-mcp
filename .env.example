# QRadar console URL. Include http:// only for explicitly allowed private/internal networks.
QRADAR_HOST=http://192.168.1.10
QRADAR_ALLOW_PLAIN_HTTP_PRIVATE_NETWORK=true
QRADAR_API_VERSION=27.0
QRADAR_COMPATIBILITY_FAIL_MODE=closed
QRADAR_AUTH_IDENTITY_PROBE=strict

# MCP server bind inside the container. docker-compose publishes this to
# 127.0.0.1:5001 by default.
MCP_HOST=0.0.0.0
MCP_PORT=5000
# Required when MCP_HOST is 0.0.0.0 or ::. Use a long random value.
# MCP_ACCESS_TOKEN=replace-with-long-random-token
LOG_LEVEL=info
